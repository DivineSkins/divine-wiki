# Security + caching headers for STATIC ASSETS ONLY. On Workers static
# assets, _headers never applies to Worker-generated responses (SSR pages,
# /api/*): those get their headers from next.config.mjs headers() or the
# route handlers themselves.

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.ico
  Cache-Control: public, max-age=86400
